# ============================================================
#   Autonomous AI Incident Response Orchestrator
#   Environment Configuration
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_PASSWORD=kestra_secret

# ── OpenAI ────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="open api key "
OPENAI_MODEL=gpt-4o

# ── Slack ─────────────────────────────────────────────────
# Create an incoming webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── GitHub ────────────────────────────────────────────────
# Personal access token with repo scope
GITHUB_TOKEN=ghp_your_github_token_here
# Format: owner/repo  (e.g., myorg/incident-tracker)
GITHUB_REPO=your-org/your-repo

# ── Incident Service ──────────────────────────────────────
INCIDENT_SERVICE_URL=http://incident-service:8000
# Probability of simulated failure per request (0.0 - 1.0)
FAILURE_PROBABILITY=0.3

# ── Kestra ────────────────────────────────────────────────
KESTRA_URL=http://localhost:8080
